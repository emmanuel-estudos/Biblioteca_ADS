{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "emmet.includeLanguages": {
    "mdx": "typescriptreact"
  },
  "files.associations": {
      "*.mdx": "markdown"
  },
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "off",
      "strings": "off"
    },
    "editor.snippetSuggestions": "top" // Joga os seus snippets para o topo da lista de sugestões
  },
  
  // Ativa as sugestões rápidas de forma global caso o interpretador mude
  "editor.quickSuggestions": {
    "other": "on"
  }
}