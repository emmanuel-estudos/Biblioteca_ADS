{
  // Configurações Específicas para JSON
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },

  // Configurações GLOBAIS
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.detectIndentation": false,

  "editor.quickSuggestions": {
    "other": "on"
  },

  // Configurações de Equivalência de Linguagens
  "emmet.includeLanguages": {
    "mdx": "typescriptreact"
  },

  "files.associations": {
    "*.mdx": "markdown"
  },

  // Configurações Específicas para MARKDOWN
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "off",
      "strings": "off"
    },
    "editor.snippetSuggestions": "top" // Joga os seus snippets para o topo da lista de sugestões
  },

  
  // Configurações Específicas para TYPESCRIPT - REACT
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },

  // Configurações Específicas para JAVASCRIPT - REACT
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },

  // Configurações Específicas para MDX
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  }
}